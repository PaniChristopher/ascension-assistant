# Ascension Esports - Environment Variables
# Copy this file to .env and fill in your actual values
# NEVER commit .env to Git - it should be in .gitignore

# Admin Authentication
# Generate a secure hash using: node -e "console.log(require('crypto').createHash('sha256').update('YOUR_PASSWORD').digest('hex'))"
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=ef92b778bafe771e89245b89ecbc08a44a49e515f1c497c774d77c97abf7d5e7

# Session Configuration
SESSION_SECRET=your-random-session-secret-here-change-this-in-production
SESSION_EXPIRY_HOURS=1

# Rate Limiting
MAX_LOGIN_ATTEMPTS=5
RATE_LIMIT_WINDOW_MINUTES=15

# Server Configuration
PORT=8080
ENVIRONMENT=production

# Security Headers
CSP_NONCE_ENABLED=true

# Discord Bot Configuration
# Get your bot token from the Discord Developer Portal
DISCORD_BOT_TOKEN=

# Note: For production deployment, use a proper backend like Node.js, Python Flask/Django,
# or platform-level protection (Netlify Identity, Cloudflare Access, etc.)
# This static-site approach is a temporary measure.
